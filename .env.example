# USAGE INSTRUCTIONS:
# 1. Dev: Copy this file to `.env.local` (this file is gitignored by default).
# 2. Prod on VPS: Create `.env.production` at the project root before running `npm run build`.
# 3. Prod on Docker: Pass these variables via `docker-compose.yml` env_file, or ARG/ENV in the Dockerfile.
# 4. Vite Context: Vite automatically sets `import.meta.env.MODE` to 'development' or 'production' 
#    based on the command run (`vite` vs `vite build`). You do not need to manually set NODE_ENV.
# 5. Prefix Rule: ALL variables must be prefixed with `VITE_` to be exposed to the browser.
# 6. Access in code: Use `import.meta.env.VITE_KEY_NAME`.

# --- SITE IDENTITY ---
# Accessed by: SEO Components (Helmet), Navbar, Footer
VITE_SITE_NAME="LegalSupportNow"
VITE_SITE_URL="https://legalsupportnow.com"
VITE_SITE_DESCRIPTION="Premium criminal defense law firm serving Delhi NCR with authority and precision."

# --- CONTACT & BUSINESS INFO ---
# Accessed by: Contact Page, Footer, Navbar, WhatsApp Widget
VITE_CONTACT_PHONE="+919876543210"
VITE_CONTACT_PHONE_DISPLAY="+91 98765 43210"
VITE_CONTACT_EMAIL="consult@legalsupportnow.com"
VITE_CONTACT_ADDRESS="123 Legal Avenue, Connaught Place, New Delhi, Delhi 110001"
VITE_CONTACT_MAPS_URL="https://maps.google.com/?q=Connaught+Place+New+Delhi"
VITE_WHATSAPP_NUMBER="919876543210"
VITE_WHATSAPP_DEFAULT_MESSAGE="Hello, I need urgent legal assistance."

# --- BUSINESS HOURS ---
# Accessed by: Footer, Contact Page
VITE_BUSINESS_HOURS="Mon-Sat: 9AM-7PM, Sun: By Appointment"

# --- SOCIAL MEDIA (Optional) ---
# Accessed by: Footer Social Links
VITE_SOCIAL_FACEBOOK="https://facebook.com/legalsupportnow"
VITE_SOCIAL_INSTAGRAM="https://instagram.com/legalsupportnow"
VITE_SOCIAL_LINKEDIN="https://linkedin.com/company/legalsupportnow"
VITE_SOCIAL_YOUTUBE=""

# --- ANALYTICS & TRACKING (Optional) ---
# Accessed by: Main Layout/Index (Analytics Scripts)
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_GTM_ID="GTM-XXXXXX"
VITE_META_PIXEL_ID=""
VITE_CLARITY_ID=""

# --- FORMS & COMMUNICATION ---
# Accessed by: Contact Form Component
# Note: For static sites, Web3Forms is highly recommended over Formspree as it doesn't 
# redirect the user to an external "Thank You" page by default on the free tier, allowing
# for seamless inline success messages in your React Hook Form.
VITE_WEB3FORMS_KEY="your-web3forms-access-key"
VITE_RECAPTCHA_SITE_KEY="your-recaptcha-v3-site-key"

# --- SEO & STRUCTURED DATA ---
# Accessed by: SEO/Schema Components (Helmet)
VITE_SCHEMA_LAWYER_NAME="LegalSupportNow Defense"
VITE_SCHEMA_BAR_ID="D/1234/2010"
VITE_SCHEMA_FOUNDING_YEAR="2010"

# --- FEATURE FLAGS ---
# Accessed by: App.jsx, Layout Components
VITE_ENABLE_WHATSAPP_WIDGET="true"
VITE_ENABLE_LIVE_CHAT="false"
VITE_ENABLE_BLOG="true"
VITE_MAINTENANCE_MODE="false"
